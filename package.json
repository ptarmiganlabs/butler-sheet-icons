{
    "name": "butler-sheet-icons",
    "version": "3.11.0",
    "description": "Creates thumbnail images based on sheets in Qlik Sense applications",
    "type": "module",
    "main": "src/butler-sheet-icons.js",
    "scripts": {
        "jest": "node --experimental-vm-modules --no-warnings node_modules/jest/bin/jest.js --runInBand --detectOpenHandles --forceExit",
        "jest:watch": "node --experimental-vm-modules --no-warnings node_modules/jest/bin/jest.js --runInBand",
        "test": "npm run test:unit && npm run test:integration",
        "test:unit": "npm run jest -- --testPathIgnorePatterns=\\.integration\\.test\\.js$ --coverage",
        "test:integration": "npm run jest -- --testPathPatterns=\\.integration\\.test\\.js$",
        "test:watch": "npm run jest:watch -- --testPathIgnorePatterns=\\.integration\\.test\\.js$ --watch",
        "lint": "npx eslint src/ --max-warnings 0",
        "lint:fix": "npx eslint --fix src/",
        "format": "npx prettier --write \"src/**/*.js\"",
        "build:macos": "./build-script/build-macos.sh"
    },
    "author": "Göran Sander mountaindude@ptarmiganlabs.com",
    "license": "MIT",
    "engines": {
        "node": ">=24.0.0"
    },
    "keywords": [
        "qlik",
        "sense",
        "qliksense",
        "butler",
        "butler-sheet-icons",
        "thumbnails",
        "screenshot"
    ],
    "dependencies": {
        "@puppeteer/browsers": "^3.0.0",
        "axios": "^1.18.1",
        "cli-progress": "^3.12.0",
        "commander": "^14.0.3",
        "dotenv": "^17.4.2",
        "enigma.js": "^2.14.0",
        "form-data": "^4.0.6",
        "fs-extra": "^11.3.5",
        "jimp": "^1.6.1",
        "os": "^0.1.2",
        "puppeteer-core": "^25.0.0",
        "qrs-interact": "^6.3.1",
        "table": "^6.9.0",
        "upath": "^3.0.7",
        "winston": "^3.19.0",
        "ws": "^8.21.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@jest/globals": "^30.4.1",
        "esbuild": "^0.28.1",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsdoc": "^63.0.2",
        "eslint-plugin-prettier": "^5.5.6",
        "globals": "^17.6.0",
        "jest": "^30.4.2",
        "prettier": "^3.8.4",
        "snyk": "^1.1305.1"
    },
    "repository": {
        "type": "git",
        "url": "git://github.com/ptarmiganlabs/butler-sheet-icons.git"
    },
    "homepage": "https://github.com/ptarmiganlabs/butler-sheet-icons",
    "bugs": {
        "url": "https://github.com/ptarmiganlabs/butler-sheet-icons/issues"
    }
}
